//@version=6
indicator("1分毎アラート", overlay=true)

// 1分ごとにトリガー（新しい分に変わったとき）
triggerAlert = not na(ta.change(time("1"))) and ta.change(time("1")) != 0

// アラート条件（Webhook 用 JSON: 通貨と action を返す。action は buy 固定）
// message は const string である必要があるため、リテラルを直接指定
alertcondition(triggerAlert, title="1分毎アラート", message="{\"symbol\":\"{{ticker}}\",\"action\":\"buy\"}")
