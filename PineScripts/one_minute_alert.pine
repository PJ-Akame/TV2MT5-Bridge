//@version=6
indicator("1分毎アラート", overlay=true)

// 1分ごとにトリガー（新しい分に変わったとき）
triggerAlert = not na(ta.change(time("1"))) and ta.change(time("1")) != 0

// アラート条件（Webhook 用 JSON メッセージ）
alertcondition(triggerAlert, title="1分毎アラート", message='{"time":"{{timenow}}","interval":"1m","symbol":"{{ticker}}"}')
