//@version=6
indicator("SMC Execution Signal", overlay=true)

// ═══════════════════════════════════════════════════════════════════
// Input Parameters (configurable from TradingView)
// ═══════════════════════════════════════════════════════════════════

// Tokyo Session
int tokyoMuteHours = input.int(
     0,
     "Tokyo: Mute hours after session open",
     minval=-1,
     tooltip="-1 = Exclude Tokyo session from trading",
     group="Session Filter"
 )

// London Session
int londonMuteHours = input.int(
     0,
     "London: Mute hours after session open",
     minval=-1,
     tooltip="-1 = Exclude London session from trading",
     group="Session Filter"
 )

// New York Session
int nyMuteHours = input.int(
     0,
     "New York: Mute hours after session open",
     minval=-1,
     tooltip="-1 = Exclude New York session from trading",
     group="Session Filter"
 )

// Economic News
int newsMuteHoursBefore = input.int(
     -1,
     "News: Mute hours before release",
     minval=-1,
     tooltip="Negative = disabled",
     group="News Filter"
 )

int newsMuteHoursAfter = input.int(
     -1,
     "News: Mute hours after release",
     minval=-1,
     tooltip="Negative = disabled",
     group="News Filter"
 )

// Volatility
int volatilityFloor = input.int(
     0,
     "Min volatility (suppress alert if below)",
     minval=0,
     group="Volatility Filter"
 )

// Risk Management
int stopLossPips = input.int(
     0,
     "Stop loss (pips)",
     minval=0,
     group="Risk Management"
 )

// ═══════════════════════════════════════════════════════════════════
// Mxwll Suite Reference (add Lib_MxwllSuite to chart first)
// ═══════════════════════════════════════════════════════════════════

float mxwllBuyTrigger  = input.source(close, "Buy Trigger (1=fire)", group="Mxwll Suite")
float mxwllSellTrigger = input.source(close, "Sell Trigger (1=fire)", group="Mxwll Suite")
float mxwllObPct      = input.source(close, "OB % (for alert)", group="Mxwll Suite")

// ═══════════════════════════════════════════════════════════════════
// Filter Logic
// ═══════════════════════════════════════════════════════════════════

int nyHour   = hour(timenow, "America/New_York")
int nyMinute = minute(timenow, "America/New_York")

// Session ranges (NY time): Tokyo 20-02, London 03-11:30, NY 09:30-16
bool inTokyo  = (nyHour >= 20) or (nyHour < 2)
bool inLondon = (nyHour >= 3 and nyHour < 11) or (nyHour == 11 and nyMinute <= 30)
bool inNY     = (nyHour > 9 or (nyHour == 9 and nyMinute >= 30)) and (nyHour < 16 or (nyHour == 16 and nyMinute <= 0))

// Mute: X hours after session open. -1 = exclude entire session
float tokyoElapsed  = inTokyo ? ((nyHour >= 20 ? (nyHour - 20) * 60 + nyMinute : (24 - 20) * 60 + nyHour * 60 + nyMinute) / 60.0) : 0.0
float londonElapsed = inLondon ? ((nyHour - 3) * 60 + nyMinute) / 60.0 : 0.0
float nyElapsed    = inNY ? ((nyHour - 9) * 60 + (nyMinute - 30)) / 60.0 : 0.0

bool tokyoMuted  = tokyoMuteHours < 0 ? inTokyo : (inTokyo and tokyoElapsed < tokyoMuteHours)
bool londonMuted = londonMuteHours < 0 ? inLondon : (inLondon and londonElapsed < londonMuteHours)
bool nyMuted     = nyMuteHours < 0 ? inNY : (inNY and nyElapsed < nyMuteHours)

bool sessionMuted = tokyoMuted or londonMuted or nyMuted

// Volatility: ATR below floor = mute (placeholder: 0 = disabled)
float atrVal = ta.atr(14)
bool volMuted = volatilityFloor > 0 and atrVal < volatilityFloor * syminfo.mintick * 10

// News filter: placeholder (no news data source)
bool newsMuted = false

// Final: trigger AND not muted
bool buyOk  = mxwllBuyTrigger == 1 and not sessionMuted and not volMuted and not newsMuted
bool sellOk = mxwllSellTrigger == 1 and not sessionMuted and not volMuted and not newsMuted

// Output（plot の順序: plot_0=OB%, plot_1=na）
plot(mxwllObPct, "OB %", display=display.none)  // アラートで {{plot_0}} として取得
plot(na, display=display.none)

plotshape(buyOk, style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small)
plotshape(sellOk, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)

// アラートメッセージ: Webhook 用 JSON（{{plot_0}}=obPct）
alertcondition(buyOk, "SMC Buy Signal", '{"symbol":"{{ticker}}","action":"buy","obPct":{{plot_0}}}')
alertcondition(sellOk, "SMC Sell Signal", '{"symbol":"{{ticker}}","action":"sell","obPct":{{plot_0}}}')

// ------------------------------------------------------------------------
